# Google Apps Script web app URL (Deploy → Web app → copy /exec URL)
GOOGLE_APPS_SCRIPT_URL=

# Google Maps Platform — enables Google visuals on browse map + static previews.
# Enable Maps JavaScript API + Static Maps API in Google Cloud Console.
# Restrict key by HTTP referrer (production domain + localhost).
VITE_GOOGLE_MAPS_API_KEY=

# Optional: protect admin write actions (update status, promote to Events tab)
# Set the same value in Netlify env and VITE_PUDDLES_API_KEY for the admin dashboard
PUDDLES_API_SECRET=
VITE_PUDDLES_API_KEY=

# Admin dashboard password (server-only — set on Netlify, not in VITE_* vars)
# When set, /admin requires sign-in and CSV/API proxies check the session cookie.
ADMIN_PASSWORD=
# Optional: separate secret for signing admin session cookies (defaults to ADMIN_PASSWORD)
ADMIN_SESSION_SECRET=

# Plausible analytics loads automatically on puddlesmap.com (see index.html).
# Admin "Publish to site" — GitHub fine-grained PAT with Actions: Read and write on this repo.
# Create at github.com/settings/tokens?type=beta → Repository access: puddles-v2 only.
GITHUB_DEPLOY_TOKEN=
# Optional override (default: puddlesmap/puddles-v2)
# GITHUB_REPO=puddlesmap/puddles-v2
